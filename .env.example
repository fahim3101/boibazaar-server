# MongoDB Atlas connection string (get from Atlas dashboard -> Connect -> Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/boibazaar?retryWrites=true&w=majority

# Any long random string, used to sign JWT tokens
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port for local dev (Vercel ignores this in production)
PORT=5000

# Your deployed frontend URL (for CORS). For local dev, keep as is.
CLIENT_URL=http://localhost:3000

# Firebase Admin credentials (for Google/Facebook social login verification)
# Get these from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
